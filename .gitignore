# ============================================
# KEEP THESE FOLDERS (empty folders)
# ============================================
# Git doesn't track empty folders
# These .gitkeep files ensure folders exist
!data/raw/.gitkeep
!data/processed/.gitkeep
!results/models/.gitkeep
!results/figures/.gitkeep
!results/metrics/.gitkeep
!notebooks/.gitkeep